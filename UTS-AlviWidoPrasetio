        "import numpy as np\n",
        "\n",
        "scores = np.array([\n",
        "    [80, 85, 90],\n",
        "    [70, 60, 75],\n",
        "    [95, 90, 100],\n",
        "    [40, 50, 45]\n",
        "])\n",
        "\n",
        "# Rata-rata tiap mahasiswa\n",
        "rata_rata = np.mean(scores, axis=1)\n",
        "\n",
        "# Nilai tertinggi\n",
        "nilai_tertinggi = np.max(scores)\n",
        "\n",
        "# Status kelulusan\n",
        "status = np.where(rata_rata >= 70, \"Lulus\", \"Gagal\")\n",
        "\n",
        "print(\"Rata-rata Mahasiswa:\")\n",
        "print(rata_rata)\n",
        "\n",
        "print(\"\\nNilai Tertinggi:\")\n",
        "print(nilai_tertinggi)\n",
        "\n",
        "print(\"\\nStatus Kelulusan:\")\n",
        "print(status)"
      ],
